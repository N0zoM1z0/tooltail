<Window x:Class="Tooltail.Desktop.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        xmlns:controls="clr-namespace:Tooltail.Desktop.Controls"
        Title="Tooltail Home"
        Width="900"
        Height="720"
        MinWidth="720"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
        automation:AutomationProperties.Name="Tooltail home and window context controls">
  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground"
              Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style TargetType="GroupBox">
      <Setter Property="Margin" Value="0,0,0,14" />
      <Setter Property="Padding" Value="12" />
    </Style>
    <Style TargetType="Button">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="Margin" Value="0,0,8,8" />
    </Style>
  </Window.Resources>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto"
                Focusable="True"
                automation:AutomationProperties.Name="Scrollable Tooltail home content">
    <StackPanel Margin="24">
      <TextBlock FontSize="30"
                 FontWeight="SemiBold"
                 Text="Tooltail Home" />
      <TextBlock Margin="0,4,0,20"
                 FontSize="15"
                 Text="Choose a visible context, inspect exact identity, or return the companion home. No login or model key is required." />

      <GroupBox Header="Context is not authority"
                automation:AutomationProperties.Name="Window context and resource authority disclosure">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Window context" />
          <TextBlock Margin="0,3,0,10"
                     Text="Window position limits Tooltail's context. It is not an operating-system sandbox." />
          <TextBlock FontWeight="SemiBold" Text="Resource authority" />
          <TextBlock Margin="0,3,0,0"
                     Text="A WindowLease grants no file, UI, network, shell, model, or process action. Actual actions require a separate exact ResourceGrant and approval." />
        </StackPanel>
      </GroupBox>

      <GroupBox Header="File Apprentice — local persisted state"
                DataContext="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=FileApprentice}"
                automation:AutomationProperties.Name="File Apprentice first run and persisted state">
        <StackPanel>
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Text="{Binding Headline}"
                     automation:AutomationProperties.LiveSetting="Polite" />
          <TextBlock Margin="0,4,0,12"
                     Text="No login, model key, chat setup, telemetry, or customization is required. A safe lab or deliberately selected folder grant is separate from window placement." />
          <Border Margin="0,0,0,12"
                  Padding="10"
                  BorderBrush="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                  BorderThickness="1"
                  automation:AutomationProperties.Name="Committed File Apprentice body truth">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="145" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <controls:AgentBodyControl Body="{Binding CurrentBody}"
                                         AccessibleName="{Binding BodyAccessibleName}"
                                         ReducedMotion="True"
                                         Height="125"
                                         Margin="0,0,12,0" />
              <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock FontWeight="SemiBold" Text="Deterministic body projection" />
                <TextBlock FontFamily="Consolas"
                           Text="{Binding CurrentBody.State, StringFormat=State: {0}}" />
                <TextBlock FontFamily="Consolas"
                           Text="{Binding CurrentBody.ToolKind, StringFormat=Tool prop: {0}, TargetNullValue=Tool prop: none}" />
                <TextBlock FontFamily="Consolas"
                           Text="{Binding CurrentBody.ReasonCode, StringFormat=Body reason: {0}}" />
                <TextBlock FontFamily="Consolas"
                           Text="{Binding BodyEvidenceReasonCode, StringFormat=Evidence reason: {0}}" />
                <TextBlock Margin="0,4,0,0" Text="{Binding BodyEvidenceSummary}" />
                <TextBlock Margin="0,4,0,0"
                           Text="The body is presentation only. It cannot create a grant, approval, plan, or effect." />
              </StackPanel>
            </Grid>
          </Border>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,16,6" FontWeight="SemiBold" Text="Companion" />
            <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" Text="{Binding CompanionName}" />
            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,16,6" FontWeight="SemiBold" Text="Folder authority" />
            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" Text="{Binding GrantState}" />
            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,16,6" FontWeight="SemiBold" Text="Current skill" />
            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SkillState}" />
            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,16,6" FontWeight="SemiBold" Text="Teaching" />
            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,6" Text="{Binding LessonState}" />
            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,16,6" FontWeight="SemiBold" Text="Execution" />
            <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,0,0,6" Text="{Binding ExecutionState}" />
            <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,16,6" FontWeight="SemiBold" Text="Recovery" />
            <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,0,0,6" Text="{Binding RecoveryState}" />
            <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,0,16,6" FontWeight="SemiBold" Text="Safe lab path" />
            <TextBlock Grid.Row="6" Grid.Column="1" Margin="0,0,0,6" FontFamily="Consolas" Text="{Binding LabPath}" />
            <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,0,16,0" FontWeight="SemiBold" Text="Reason" />
            <TextBlock Grid.Row="7" Grid.Column="1" FontFamily="Consolas" Text="{Binding ReasonCode}" />
          </Grid>
          <WrapPanel Margin="0,12,0,0">
            <Button Content="Create _safe lab and grant"
                    IsEnabled="{Binding CanCreateSafeLab}"
                    Click="OnCreateSafeLabClick"
                    automation:AutomationProperties.Name="Create a new Tooltail-owned safe lab and exact folder grant" />
            <Button Content="_Start teaching"
                    IsEnabled="{Binding CanStartTeaching}"
                    Click="OnStartTeachingClick"
                    automation:AutomationProperties.Name="Capture baseline and start teaching observation" />
            <Button Content="S_top and reconcile"
                    IsEnabled="{Binding CanStopTeaching}"
                    Click="OnStopTeachingClick"
                    automation:AutomationProperties.Name="Stop teaching and reconcile authoritative snapshots" />
          </WrapPanel>
          <TextBlock Margin="0,4,0,0"
                     Text="Teaching is user-driven: after Start, use File Explorer to create an Invoices folder and move at least two synthetic PDFs with the same safe rename pattern. Tooltail records no global input. Then return here and choose Stop and reconcile." />
          <Button Margin="0,10,8,4"
                  HorizontalAlignment="Left"
                  Content="_Compile or answer questions"
                  IsEnabled="{Binding CanCompileSkill}"
                  Click="OnCompileSkillClick"
                  automation:AutomationProperties.Name="Compile reconciled teaching examples or submit typed clarifications" />
          <ItemsControl ItemsSource="{Binding CompilerQuestions}"
                        automation:AutomationProperties.Name="Deterministic compiler clarification questions">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="0,6,0,4">
                  <TextBlock FontWeight="SemiBold" Text="{Binding Prompt}" />
                  <ComboBox Margin="0,4,0,0"
                            MinHeight="34"
                            ItemsSource="{Binding Options}"
                            DisplayMemberPath="Label"
                            SelectedValuePath="Value"
                            SelectionChanged="OnCompilerAnswerChanged"
                            automation:AutomationProperties.Name="Typed compiler answer" />
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <controls:SkillCardControl Card="{Binding SkillCard}"
                                     ActionRequested="OnSkillCardActionRequested">
            <controls:SkillCardControl.Style>
              <Style TargetType="controls:SkillCardControl">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding HasSkillCard}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </controls:SkillCardControl.Style>
          </controls:SkillCardControl>
          <Button Margin="0,10,8,4"
                  HorizontalAlignment="Left"
                  Content="_Rehearse Draft"
                  IsEnabled="{Binding CanRehearseSkill}"
                  Click="OnRehearseSkillClick"
                  automation:AutomationProperties.Name="Rehearse the Draft in a Tooltail-owned temporary root" />
          <Border Margin="0,8,0,0"
                  Padding="10"
                  BorderBrush="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                  BorderThickness="1">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding HasRehearsalPlan}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <StackPanel DataContext="{Binding RehearsalPlan}">
              <TextBlock FontSize="16" FontWeight="SemiBold" Text="Verified rehearsal and exact production plan" />
              <TextBlock Margin="0,4,0,0" TextWrapping="Wrap"
                         Text="The shared executor verified a Tooltail-owned copy. The production plan below is persisted but not approved and cannot execute." />
              <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="Plan fingerprint" />
              <TextBlock FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding Fingerprint}" />
              <TextBlock Margin="0,4,0,0" FontFamily="Consolas" Text="{Binding PlanId, StringFormat=Plan ID: {0}}" />
              <TextBlock FontFamily="Consolas" Text="{Binding GrantId, StringFormat=Grant ID: {0}}" />
              <TextBlock FontFamily="Consolas" Text="{Binding ExpiresUtc, StringFormat=Expires UTC: {0}}" />
              <TextBlock Margin="0,4,0,0" Text="{Binding MatchedFileCount, StringFormat=Matched files: {0}}" />
              <TextBlock Text="{Binding VerifiedRehearsalStepCount, StringFormat=Verified rehearsal steps: {0}}" />
              <TextBlock Text="{Binding CleanupReasonCode, StringFormat=Owned cleanup: {0}}" />
              <TextBlock Text="{Binding RetirementReasonCode, StringFormat=Temporary grant: {0}}" />
              <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Operations}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,2" Padding="6"
                            BorderBrush="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                            BorderThickness="0,0,0,1">
                      <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="{Binding Primitive}" />
                        <TextBlock FontFamily="Consolas" Text="{Binding Source, StringFormat=From: {0}}" />
                        <TextBlock FontFamily="Consolas" Text="{Binding Destination, StringFormat=To: {0}}" />
                        <TextBlock Text="{Binding ExpectedResult, StringFormat=Expected: {0}}" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock Margin="0,10,0,4"
                         FontWeight="SemiBold"
                         Text="This decision applies only to the exact fingerprint above. Any material replan requires a new decision." />
              <Button HorizontalAlignment="Left"
                      Content="_Approve exact plan and execute"
                      IsEnabled="{Binding RelativeSource={RelativeSource AncestorType=GroupBox}, Path=DataContext.CanApproveAndExecute}"
                      Click="OnApproveAndExecuteClick"
                      automation:AutomationProperties.Name="Approve the exact displayed fingerprint and execute once" />
            </StackPanel>
          </Border>
          <Border Margin="0,8,0,0"
                  Padding="10"
                  BorderBrush="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"
                  BorderThickness="2">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding HasExecutionReceipt}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <StackPanel DataContext="{Binding ExecutionReceipt}">
              <TextBlock FontSize="18" FontWeight="SemiBold" Text="Verified production receipt" />
              <TextBlock Margin="0,4,0,8"
                         Text="Success is shown only after the journal, postconditions, verified evidence, and receipt agree." />
              <TextBlock FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding ReceiptId, StringFormat=Receipt ID: {0}}" />
              <TextBlock FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding ExecutionId, StringFormat=Execution ID: {0}}" />
              <TextBlock FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding PlanId, StringFormat=Plan ID: {0}}" />
              <TextBlock FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding PlanFingerprint, StringFormat=Fingerprint: {0}}" />
              <TextBlock Text="{Binding CompletedUtc, StringFormat=Completed UTC: {0}}" />
              <TextBlock Text="{Binding UndoAvailableUntilUtc, StringFormat=Undo available until UTC: {0}}" />
              <TextBlock Text="{Binding VerifiedStepCount, StringFormat=Verified steps: {0}}" />
              <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding VerifiedSteps}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Margin="0,3">
                      <TextBlock FontWeight="SemiBold" Text="{Binding Primitive}" />
                      <TextBlock FontFamily="Consolas" Text="{Binding Source, StringFormat=From: {0}}" />
                      <TextBlock FontFamily="Consolas" Text="{Binding Destination, StringFormat=To: {0}}" />
                      <TextBlock FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding DestinationIdentity, StringFormat=Verified destination identity: {0}}" />
                      <TextBlock FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding ContentSha256, StringFormat=SHA-256: {0}, TargetNullValue=SHA-256: not applicable}" />
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <Button Margin="0,10,8,4"
                      HorizontalAlignment="Left"
                      Content="_Plan Undo"
                      IsEnabled="{Binding RelativeSource={RelativeSource AncestorType=GroupBox}, Path=DataContext.CanPlanUndo}"
                      Click="OnPlanUndoClick"
                      automation:AutomationProperties.Name="Plan Undo from the verified receipt and current snapshot" />
            </StackPanel>
          </Border>
          <Border Margin="0,8,0,0"
                  Padding="10"
                  BorderBrush="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                  BorderThickness="1">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding HasUndoPlan}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <StackPanel DataContext="{Binding UndoPlan}">
              <TextBlock FontSize="18" FontWeight="SemiBold" Text="Exact Undo recovery preview" />
              <TextBlock Margin="0,4,0,8"
                         Text="This is a newly planned operation derived from the verified receipt, exact original journal, and current snapshot. It is not a blind rollback and is not approved." />
              <TextBlock FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding Fingerprint, StringFormat=Recovery fingerprint: {0}}" />
              <TextBlock FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding PlanId, StringFormat=Recovery plan ID: {0}}" />
              <TextBlock FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding OriginalExecutionId, StringFormat=Original execution ID: {0}}" />
              <TextBlock FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding OriginalPlanFingerprint, StringFormat=Original fingerprint: {0}}" />
              <TextBlock Text="{Binding ExpiresUtc, StringFormat=Expires UTC: {0}}" />
              <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Operations}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Margin="0,3">
                      <TextBlock FontWeight="SemiBold" Text="{Binding Primitive}" />
                      <TextBlock FontFamily="Consolas" Text="{Binding Source, StringFormat=From: {0}}" />
                      <TextBlock FontFamily="Consolas" Text="{Binding Destination, StringFormat=To: {0}}" />
                      <TextBlock FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding ExpectedIdentity, StringFormat=Expected unchanged identity: {0}}" />
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock Margin="0,8,0,4" FontWeight="SemiBold"
                         Text="A new undo-only approval is required for exactly this recovery fingerprint." />
              <Button HorizontalAlignment="Left"
                      Content="Approve exact _Undo and restore"
                      IsEnabled="{Binding RelativeSource={RelativeSource AncestorType=GroupBox}, Path=DataContext.CanApproveUndo}"
                      Click="OnApproveUndoClick"
                      automation:AutomationProperties.Name="Approve the exact recovery fingerprint and execute Undo once" />
            </StackPanel>
          </Border>
          <Border Margin="0,8,0,0"
                  Padding="10"
                  BorderBrush="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"
                  BorderThickness="2">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding HasUndoReceipt}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <StackPanel DataContext="{Binding UndoReceipt}">
              <TextBlock FontSize="18" FontWeight="SemiBold" Text="Verified Undo receipt" />
              <TextBlock Margin="0,4,0,8"
                         Text="The original receipt is retained. This separate receipt links the recovery execution to each rolled-back original step." />
              <TextBlock FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding ReceiptId, StringFormat=Receipt ID: {0}}" />
              <TextBlock FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding ExecutionId, StringFormat=Recovery execution ID: {0}}" />
              <TextBlock FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding PlanFingerprint, StringFormat=Recovery fingerprint: {0}}" />
              <TextBlock FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding OriginalExecutionId, StringFormat=Original execution ID: {0}}" />
              <TextBlock FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding OriginalPlanFingerprint, StringFormat=Original fingerprint: {0}}" />
              <TextBlock Text="{Binding CompletedUtc, StringFormat=Completed UTC: {0}}" />
              <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding VerifiedSteps}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Margin="0,3">
                      <TextBlock FontWeight="SemiBold" Text="{Binding Primitive}" />
                      <TextBlock FontFamily="Consolas" Text="{Binding Source, StringFormat=From: {0}}" />
                      <TextBlock FontFamily="Consolas" Text="{Binding Destination, StringFormat=To: {0}}" />
                      <TextBlock FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding RecoveredIdentity, StringFormat=Recovered identity: {0}}" />
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
          <Button Margin="0,10,8,4"
                  HorizontalAlignment="Left"
                  Content="Create _corrected Draft v2"
                  IsEnabled="{Binding CanCreateCorrection}"
                  Click="OnCreateCorrectionClick"
                  ToolTip="Explicitly broaden origin and filename scope; produces Draft only"
                  automation:AutomationProperties.Name="Create a parent-linked corrected Draft that requires new rehearsal" />
          <Button Margin="0,4,8,4"
                  HorizontalAlignment="Left"
                  Content="_Export companion capsule"
                  IsEnabled="{Binding CanExportCapsule}"
                  Click="OnExportCapsuleClick"
                  automation:AutomationProperties.Name="Export validated companion history without authority" />
          <Border Margin="0,8,0,0"
                  Padding="10"
                  BorderBrush="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                  BorderThickness="1">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding HasCapsuleExport}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <StackPanel DataContext="{Binding CapsuleExport}">
              <TextBlock FontSize="18" FontWeight="SemiBold" Text="Validated local companion capsule" />
              <TextBlock Margin="0,4,0,8"
                         Text="The file contains immutable SkillSpecs and bounded summaries only. Import is intentionally disabled; every skill would require a new grant, explicit rebind, and rehearsal." />
              <TextBlock FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding CanonicalPath, StringFormat=Local path: {0}}" />
              <TextBlock Text="{Binding ByteCount, StringFormat=Bytes: {0}}" />
              <TextBlock Text="{Binding SkillVersionCount, StringFormat=Skill versions: {0}}" />
              <TextBlock FontFamily="Consolas" Text="{Binding PreviewReasonCode, StringFormat=Preview: {0}}" />
              <TextBlock Text="{Binding CreatesAuthority, StringFormat=Creates authority: {0}}" />
              <TextBlock Text="{Binding CanImport, StringFormat=Native import enabled: {0}}" />
              <TextBlock Text="{Binding SkillsRequireRebind, StringFormat=Skills require rebind/rehearsal: {0}}" />
            </StackPanel>
          </Border>
          <Border Margin="0,12,0,0"
                  Padding="10"
                  BorderBrush="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                  BorderThickness="1">
            <TextBlock Text="{Binding LastActionMessage}"
                       automation:AutomationProperties.Name="Latest File Apprentice startup result"
                       automation:AutomationProperties.LiveSetting="Polite" />
          </Border>
        </StackPanel>
      </GroupBox>

      <GroupBox Header="Current window context"
                automation:AutomationProperties.Name="Current window context summary">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Grid.Column="0"
                     Margin="0,0,16,6"
                     FontWeight="SemiBold"
                     Text="State" />
          <TextBlock Grid.Row="0" Grid.Column="1"
                     Margin="0,0,0,6"
                     FontSize="18"
                     FontWeight="SemiBold"
                     Text="{Binding Headline}"
                     automation:AutomationProperties.LiveSetting="Polite" />
          <TextBlock Grid.Row="1" Grid.Column="0"
                     Margin="0,0,16,6"
                     FontWeight="SemiBold"
                     Text="Application" />
          <TextBlock Grid.Row="1" Grid.Column="1"
                     Margin="0,0,0,6"
                     Text="{Binding ApplicationName}" />
          <TextBlock Grid.Row="2" Grid.Column="0"
                     Margin="0,0,16,6"
                     FontWeight="SemiBold"
                     Text="Window title" />
          <TextBlock Grid.Row="2" Grid.Column="1"
                     Margin="0,0,0,6"
                     Text="{Binding WindowTitle}" />
          <TextBlock Grid.Row="3" Grid.Column="0"
                     Margin="0,0,16,6"
                     FontWeight="SemiBold"
                     Text="Reason" />
          <TextBlock Grid.Row="3" Grid.Column="1"
                     Margin="0,0,0,6"
                     FontFamily="Consolas"
                     Text="{Binding ReasonCode}" />
          <TextBlock Grid.Row="4" Grid.Column="0"
                     Margin="0,0,16,0"
                     FontWeight="SemiBold"
                     Text="Expires UTC" />
          <TextBlock Grid.Row="4" Grid.Column="1"
                     FontFamily="Consolas"
                     Text="{Binding ExpiresUtc}" />
        </Grid>
      </GroupBox>

      <GroupBox Header="Keyboard window picker"
                automation:AutomationProperties.Name="Keyboard accessible window target picker">
        <StackPanel>
          <TextBlock Margin="0,0,0,8"
                     Text="Refresh the bounded list, choose one eligible top-level window, then attach explicitly. This is the non-drag alternative." />
          <ComboBox MinHeight="36"
                    Margin="0,0,0,10"
                    ItemsSource="{Binding EligibleTargets}"
                    SelectedItem="{Binding SelectedTarget, Mode=TwoWay}"
                    DisplayMemberPath="DisplayLabel"
                    automation:AutomationProperties.Name="Eligible window targets" />
          <WrapPanel>
            <Button Content="_Refresh targets"
                    Click="OnRefreshTargetsClick"
                    automation:AutomationProperties.Name="Refresh eligible window targets" />
            <Button Content="_Attach selected"
                    IsEnabled="{Binding CanAttach}"
                    Click="OnAttachSelectedClick"
                    automation:AutomationProperties.Name="Attach to selected window as context" />
          </WrapPanel>
        </StackPanel>
      </GroupBox>

      <GroupBox Header="Critical controls"
                automation:AutomationProperties.Name="Keyboard accessible critical companion controls">
        <StackPanel>
          <WrapPanel>
            <Button Content="Open _inspector"
                    Click="OnOpenInspectorClick"
                    automation:AutomationProperties.Name="Open exact window lease inspector" />
            <Button Content="_Unbind context"
                    IsEnabled="{Binding CanRevoke}"
                    Click="OnUnbindClick"
                    automation:AutomationProperties.Name="Revoke active window lease" />
            <Button Content="Return _home"
                    Click="OnReturnHomeClick"
                    automation:AutomationProperties.Name="Return Tooltail home and revoke context" />
            <Button Content="_Pause"
                    Click="OnPauseClick"
                    automation:AutomationProperties.Name="Pause current Tooltail execution" />
            <Button Content="_Cancel"
                    Click="OnCancelClick"
                    automation:AutomationProperties.Name="Cancel current Tooltail execution" />
            <Button Content="Agent _Body workbench"
                    Click="OnOpenAgentBodyClick"
                    automation:AutomationProperties.Name="Open Agent Body workbench" />
          </WrapPanel>
          <Border Margin="0,4,0,0"
                  Padding="10"
                  BorderBrush="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                  BorderThickness="1">
            <TextBlock Text="{Binding LastActionMessage}"
                       automation:AutomationProperties.Name="Latest window context action result"
                       automation:AutomationProperties.LiveSetting="Polite" />
          </Border>
        </StackPanel>
      </GroupBox>
    </StackPanel>
  </ScrollViewer>
</Window>
