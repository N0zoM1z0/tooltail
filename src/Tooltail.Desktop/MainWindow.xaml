<Window x:Class="Tooltail.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        Title="Tooltail"
        Width="480"
        Height="280"
        MinWidth="420"
        MinHeight="240"
        WindowStartupLocation="CenterScreen"
        automation:AutomationProperties.Name="Tooltail engineering shell">
  <Grid Margin="32">
    <StackPanel VerticalAlignment="Center">
      <TextBlock FontSize="28"
                 FontWeight="SemiBold"
                 Text="Tooltail" />
      <TextBlock Margin="0,8,0,0"
                 FontSize="16"
                 Text="Teach a workflow. Keep the skill." />
      <Border Margin="0,24,0,0"
              Padding="12"
              BorderBrush="Gray"
              BorderThickness="1"
              CornerRadius="4">
        <TextBlock x:Name="StatusText"
                   TextWrapping="Wrap" />
      </Border>
    </StackPanel>
  </Grid>
</Window>
