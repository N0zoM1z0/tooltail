<Window x:Class="Tooltail.Desktop.TetherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        Title="Tooltail context tether"
        Width="300"
        Height="200"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        Focusable="False"
        IsHitTestVisible="False"
        automation:AutomationProperties.Name="Tooltail click-through context tether">
  <Grid>
    <Rectangle Margin="2"
               RadiusX="5"
               RadiusY="5"
               Stroke="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"
               StrokeThickness="3">
      <Rectangle.Style>
        <Style TargetType="Rectangle">
          <Setter Property="StrokeDashArray" Value="1,0" />
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsPreview}" Value="True">
              <Setter Property="StrokeDashArray" Value="5,3" />
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Rectangle.Style>
    </Rectangle>
    <Border HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="10"
            Padding="8,5"
            BorderBrush="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
            BorderThickness="1"
            Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
      <StackPanel>
        <TextBlock FontWeight="SemiBold"
                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                   Text="{Binding TetherLabel}" />
        <TextBlock Margin="0,2,0,0"
                   MaxWidth="420"
                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                   Text="{Binding ApplicationName}" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
